@inherits LayoutComponentBase
@inject IStringLocalizer<LayoutResource> L

<div class="citizen-shell">
    <header class="citizen-header">
        <div class="container-xxl d-flex flex-column flex-lg-row align-items-lg-center justify-content-lg-between gap-3 py-3">
            <div>
                <a class="citizen-brand" href="/">
                    <span class="citizen-brand-mark">
                        <img class="citizen-brand-logo" src="images/beagl_logo.png" alt="@L["MainLayout.Brand.Alt"]" />
                    </span>
                    <span>@L["MainLayout.Brand.Name"]</span>
                </a>
                <p class="citizen-caption mb-0">@L["MainLayout.Caption"]</p>
            </div>
            <nav class="nav nav-pills citizen-nav" aria-label="@L["MainLayout.Navigation"]">
                <NavLink class="nav-link" href="/" Match="NavLinkMatch.All">@L["Nav.Home"]</NavLink>
                <NavLink class="nav-link" href="/profile" Match="NavLinkMatch.All">@L["Nav.Profile"]</NavLink>
                <NavLink class="nav-link" href="/account/change-password" Match="NavLinkMatch.All">@L["Nav.ChangePassword"]</NavLink>
                <AuthorizeView>
                    <form method="post" action="/account/logout">
                        <AntiforgeryToken />
                        <button type="submit" class="nav-link citizen-signout" title="@L["Nav.Logout"]">
                            <i class="bi bi-box-arrow-right me-1" aria-hidden="true"></i>@L["Nav.Logout"]
                        </button>
                    </form>
                </AuthorizeView>
            </nav>
        </div>
    </header>

    <main>
        @Body
    </main>
</div>
