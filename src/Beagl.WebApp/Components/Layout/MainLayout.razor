@inherits LayoutComponentBase
@inject IStringLocalizer<LayoutResource> L

<div class="crm-shell">
    <aside class="crm-sidebar @(_sidebarOpen ? "is-open" : "")">
        <a class="crm-sidebar__brand" href="/employee">
            <span class="crm-sidebar__brand-mark">
                <img class="crm-sidebar__brand-logo" src="images/beagl_logo.png" alt="@L["MainLayout.Brand.Alt"]" />
            </span>
            <span class="crm-sidebar__brand-name">@L["MainLayout.Brand.Name"]</span>
        </a>

        <p class="crm-sidebar__section-label">@L["MainLayout.Section.Main"]</p>
        <nav class="crm-sidebar__nav" aria-label="@L["MainLayout.Navigation"]">
            <NavLink class="crm-sidebar__link" href="/employee" Match="NavLinkMatch.All" @onclick="CloseSidebar">
                <i class="bi bi-house" aria-hidden="true"></i>
                <span>@L["Nav.Home"]</span>
            </NavLink>
            <NavLink class="crm-sidebar__link" href="/employee/users" Match="NavLinkMatch.All" @onclick="CloseSidebar">
                <i class="bi bi-people" aria-hidden="true"></i>
                <span>@L["Nav.Users"]</span>
            </NavLink>
            <AuthorizeView Roles="@AuthorizationPolicies.AdministratorRole">
                <NavLink class="crm-sidebar__link" href="/admin" Match="NavLinkMatch.All" @onclick="CloseSidebar">
                    <i class="bi bi-gear" aria-hidden="true"></i>
                    <span>@L["Nav.Admin"]</span>
                </NavLink>
            </AuthorizeView>
        </nav>

        <div class="crm-sidebar__footer">
            <NavLink class="crm-sidebar__link" href="/account/change-password" Match="NavLinkMatch.All" @onclick="CloseSidebar">
                <i class="bi bi-key" aria-hidden="true"></i>
                <span>@L["Nav.ChangePassword"]</span>
            </NavLink>
            <AuthorizeView>
                <form method="post" action="/account/logout">
                    <AntiforgeryToken />
                    <button type="submit" class="crm-sidebar__link" title="@L["Nav.Logout"]">
                        <i class="bi bi-box-arrow-left" aria-hidden="true"></i>
                        <span>@L["Nav.Logout"]</span>
                    </button>
                </form>
            </AuthorizeView>
        </div>
    </aside>

    <div class="crm-sidebar-overlay @(_sidebarOpen ? "is-visible" : "")" @onclick="CloseSidebar"></div>

    <div class="crm-main">
        <main>
            @Body
        </main>
    </div>

    <button type="button" class="crm-sidebar-toggle" @onclick="ToggleSidebar" aria-label="@L["MainLayout.ToggleMenu"]">
        <i class="bi bi-list" aria-hidden="true"></i>
    </button>
</div>

@code {
    private bool _sidebarOpen;

    private void ToggleSidebar() => _sidebarOpen = !_sidebarOpen;

    private void CloseSidebar() => _sidebarOpen = false;
}
