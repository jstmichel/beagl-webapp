@inherits LayoutComponentBase
@inject IStringLocalizer<LayoutResource> L

<div class="app-shell">
    <header class="app-shell__header">
        <div class="container-xxl d-flex flex-column flex-lg-row align-items-lg-center justify-content-lg-between gap-3 py-3">
            <div>
                <a class="app-shell__brand text-decoration-none" href="/">
                    <span class="app-shell__brand-mark">
                        <img class="app-shell__brand-logo" src="images/beagl_logo.png" alt="@L["MainLayout.Brand.Alt"]" />
                    </span>
                    <span>@L["MainLayout.Brand.Name"]</span>
                </a>
                <p class="app-shell__caption mb-0">@L["MainLayout.Caption"]</p>
            </div>
            <nav class="nav nav-pills app-shell__nav" aria-label="@L["MainLayout.Navigation"]">
                <a class="nav-link" href="/">@L["Nav.Home"]</a>
                <NavLink class="nav-link" href="/users" Match="NavLinkMatch.All">@L["Nav.Users"]</NavLink>
            </nav>
        </div>
    </header>

    <main>
        @Body
    </main>
</div>
