@page "/"
@layout CitizenLayout
@attribute [Authorize]
@inject IStringLocalizer<HomeResource> L
@inject NavigationManager NavigationManager
@inject ICitizenProfileService CitizenProfileService

<PageTitle>@L["CitizenHome.Title"]</PageTitle>

<section class="citizen-hero-section">
    <div class="container-xxl py-4 py-lg-5">
        <article class="citizen-hero">
            <p class="citizen-kicker"><i class="bi bi-person-check" aria-hidden="true"></i> @L["CitizenHome.Kicker"]</p>
            <h1 class="citizen-title">@L["CitizenHome.Hero.Title"]</h1>
            <p class="citizen-copy mb-0">@L["CitizenHome.Hero.Copy"]</p>
        </article>

        <section class="citizen-grid" aria-label="@L["CitizenHome.Services.Aria"]">
            <article class="citizen-card">
                <div class="citizen-card__icon citizen-card__icon--teal"><i class="bi bi-person-badge"></i></div>
                <h2 class="citizen-card__title">@L["CitizenHome.Service.Profile.Title"]</h2>
                <p class="citizen-card__copy">@L["CitizenHome.Service.Profile.Copy"]</p>
            </article>
            <article class="citizen-card">
                <div class="citizen-card__icon citizen-card__icon--amber"><i class="bi bi-hearts"></i></div>
                <h2 class="citizen-card__title">@L["CitizenHome.Service.Animals.Title"]</h2>
                <p class="citizen-card__copy">@L["CitizenHome.Service.Animals.Copy"]</p>
            </article>
            <article class="citizen-card">
                <div class="citizen-card__icon citizen-card__icon--rose"><i class="bi bi-credit-card"></i></div>
                <h2 class="citizen-card__title">@L["CitizenHome.Service.Payments.Title"]</h2>
                <p class="citizen-card__copy">@L["CitizenHome.Service.Payments.Copy"]</p>
            </article>
        </section>
    </div>
</section>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthenticationStateTask { get; set; }

    protected override async Task OnInitializedAsync()
    {
        ArgumentNullException.ThrowIfNull(AuthenticationStateTask);

        AuthenticationState state = await AuthenticationStateTask.ConfigureAwait(false);

        bool isEmployee = state.User.IsInRole(nameof(UserRole.Employee));
        bool isAdmin = state.User.IsInRole(nameof(UserRole.Administrator));

        if (isEmployee || isAdmin)
        {
            NavigationManager.NavigateTo("/employee", replace: true);
            return;
        }

        string? userId = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (!string.IsNullOrWhiteSpace(userId))
        {
            bool isComplete = await CitizenProfileService
                .IsProfileCompleteAsync(userId, CancellationToken.None)
                .ConfigureAwait(false);

            if (!isComplete)
            {
                NavigationManager.NavigateTo("/profile", replace: true);
            }
        }
    }
}
