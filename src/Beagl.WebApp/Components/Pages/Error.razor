@page "/error"
@inject IStringLocalizer<ErrorResource> L

<PageTitle>@L["Error.PageTitle"]</PageTitle>

<section class="users-page-shell">
    <div class="crm-content">
        <div class="users-surface mx-auto p-4 p-lg-5" style="max-width: 820px;">
            <h1 class="text-danger">@L["Error.Heading"]</h1>
            <h2 class="text-danger h5">@L["Error.Subheading"]</h2>

            <h3 class="mt-4">@L["Error.DevelopmentMode"]</h3>
            <p>@L["Error.DevelopmentMode.Description"]</p>
            <p>
                <strong>@L["Error.DevelopmentMode.Warning"]</strong>
                @L["Error.DevelopmentMode.Body"]
            </p>

            <a class="btn btn-primary mt-2" href="/employee/users">@L["NotFound.Action.Users"]</a>
        </div>
    </div>
</section>
