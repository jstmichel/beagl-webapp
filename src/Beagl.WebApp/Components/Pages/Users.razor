@page "/employee/users"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@attribute [Authorize(Policy = AuthorizationPolicies.EmployeeAccess, Roles = AuthorizationPolicies.AdministratorRole)]

<PageTitle>@L["Users.PageTitle"]</PageTitle>

<section class="users-page-shell">
    <div class="container-xxl py-4 py-lg-5">
        <div class="users-hero mb-4 mb-lg-5">
            <div>
                <p class="users-kicker mb-2">@L["Users.Kicker"]</p>
                <h1 class="display-5 fw-semibold mb-3">@L["Users.Title"]</h1>
                <p class="users-hero__copy mb-0">@L["Users.Copy"]</p>
            </div>
            <button type="button" class="btn btn-primary btn-lg users-primary-action" @onclick="OpenCreatePanel" data-testid="create-user-button">
                <i class="bi bi-person-plus me-2" aria-hidden="true"></i>
                @L["Users.Action.Create"]
            </button>
        </div>

        @if (!string.IsNullOrWhiteSpace(_statusMessage))
        {
            <div class="alert alert-success mb-4" role="status" aria-live="polite">@_statusMessage</div>
        }

        @if (!string.IsNullOrWhiteSpace(_errorMessage))
        {
            <div class="alert alert-danger mb-4" role="alert" aria-live="assertive">@_errorMessage</div>
        }

        @if (!string.IsNullOrWhiteSpace(_confirmationUrl))
        {
            <div class="alert alert-info mb-4" role="status" aria-live="polite">
                <span>@L["Users.Info.CopyManually"]</span>
                <input type="text" readonly value="@_confirmationUrl" class="form-control mt-2" onfocus="this.select()" aria-label='@L["Users.Action.CopyConfirmationLink"]' />
            </div>
        }

        <div class="users-metrics mb-4">
            <article class="users-metric-card">
                <span class="users-metric-card__icon"><i class="bi bi-people"></i></span>
                <div>
                    <p class="users-metric-card__label">@L["Users.Metric.Total"]</p>
                    <p class="users-metric-card__value">@_totalUsersCount</p>
                </div>
            </article>
            <article class="users-metric-card">
                <span class="users-metric-card__icon"><i class="bi bi-envelope-exclamation"></i></span>
                <div>
                    <p class="users-metric-card__label">@L["Users.Metric.PendingConfirmation"]</p>
                    <p class="users-metric-card__value">@_pendingConfirmationUsersCount</p>
                </div>
            </article>
            <article class="users-metric-card">
                <span class="users-metric-card__icon"><i class="bi bi-shield-lock"></i></span>
                <div>
                    <p class="users-metric-card__label">@L["Users.Metric.Locked"]</p>
                    <p class="users-metric-card__value">@_lockedOutUsersCount</p>
                </div>
            </article>
        </div>

        <div class="users-workspace">
            <section class="users-surface users-surface--table" aria-labelledby="users-directory-title">
                <div class="users-surface__header">
                    <div>
                        <h2 id="users-directory-title" class="h4 mb-1">@L["Users.Directory.Title"]</h2>
                        <p class="text-secondary mb-0">@L["Users.Directory.Description"]</p>
                    </div>
                    <label class="users-search" for="userSearch">
                        <span class="visually-hidden">@L["Users.Search.Label"]</span>
                        <i class="bi bi-search" aria-hidden="true"></i>
                        <input id="userSearch" type="search" class="form-control" placeholder="@L["Users.Search.Placeholder"]" value="@_searchText" @oninput="OnSearchInputAsync" />
                    </label>
                </div>

                @if (_isLoading)
                {
                    <div class="users-empty-state py-5">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">@L["Users.Loading"]</span>
                        </div>
                    </div>
                }
                else if (_users.Count == 0)
                {
                    <div class="users-empty-state py-5" data-testid="empty-state">
                        <div class="users-empty-state__icon"><i class="bi bi-people"></i></div>
                        <h3 class="h5">@L["Users.Empty.Title"]</h3>
                        <p class="text-secondary mb-0">@L["Users.Empty.Description"]</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table align-middle users-table mb-0">
                            <thead>
                                <tr>
                                    <th scope="col">@L["Users.Table.User"]</th>
                                    <th scope="col">@L["Users.Table.Role"]</th>
                                    <th scope="col">@L["Users.Table.Phone"]</th>
                                    <th scope="col">@L["Users.Table.Status"]</th>
                                    <th scope="col" class="text-end">@L["Users.Table.Actions"]</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (UserListItemDto user in _users)
                                {
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center gap-3">
                                                <span class="users-avatar" aria-hidden="true">@GetAvatarInitial(user)</span>
                                                <div>
                                                    <p class="fw-semibold mb-1">@user.UserName</p>
                                                    <p class="text-secondary mb-0">@user.Email</p>
                                                </div>
                                            </div>
                                        </td>
                                        <td>@LocalizeRole(user.Role)</td>
                                        <td>@FormatOptionalValue(user.PhoneNumber)</td>
                                        <td>
                                            <div class="d-flex flex-wrap gap-2">
                                                <span class="badge text-bg-light">@(user.EmailConfirmed ? L["Users.Status.EmailConfirmed"] : L["Users.Status.PendingConfirmation"])</span>
                                                @if (user.IsLockedOut)
                                                {
                                                    <span class="badge text-bg-warning">@L["Users.Status.LockedOut"]</span>
                                                }
                                                @if (user.HasRecoveryCode)
                                                {
                                                    <span class="badge text-bg-info">@L["Users.Status.RecoveryCode"]</span>
                                                }
                                            </div>
                                        </td>
                                        <td>
                                            <div class="users-actions justify-content-end">
                                                @if (!user.EmailConfirmed)
                                                {
                                                    <button
                                                        type="button"
                                                        class="users-icon-action"
                                                        @onclick="() => ConfirmUserAccountAsync(user.Id)"
                                                        data-testid="confirm-@user.Id"
                                                        aria-label='@L["Users.Action.ConfirmAccount"]'
                                                        title='@L["Users.Action.ConfirmAccount"]'
                                                        disabled="@_isSaving">
                                                        <i class="bi bi-check2-circle" aria-hidden="true"></i>
                                                    </button>
                                                }
                                                <button
                                                    type="button"
                                                    class="users-icon-action"
                                                    @onclick="() => OpenDetailsPanelAsync(user.Id)"
                                                    data-testid="details-@user.Id"
                                                    aria-label='@L["Users.Action.Details"]'
                                                    title='@L["Users.Action.Details"]'>
                                                    <i class="bi bi-eye" aria-hidden="true"></i>
                                                </button>
                                                <button
                                                    type="button"
                                                    class="users-icon-action"
                                                    @onclick="() => OpenEditPanelAsync(user.Id)"
                                                    data-testid="edit-@user.Id"
                                                    aria-label='@L["Users.Action.Edit"]'
                                                    title='@L["Users.Action.Edit"]'>
                                                    <i class="bi bi-pencil-square" aria-hidden="true"></i>
                                                </button>
                                                <button
                                                    type="button"
                                                    class="users-icon-action users-icon-action--danger"
                                                    @onclick="() => OpenDeletePanelAsync(user.Id)"
                                                    data-testid="delete-@user.Id"
                                                    aria-label='@L["Users.Action.Delete"]'
                                                    title='@L["Users.Action.Delete"]'>
                                                    <i class="bi bi-trash3" aria-hidden="true"></i>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="users-pagination">
                        <p class="text-secondary mb-0">@L["Users.Pagination.Summary", PageStartIndex, PageEndIndex, _filteredUsersCount]</p>
                        <div class="btn-group" role="group" aria-label="@L["Users.Pagination.Aria"]">
                            <button type="button" class="btn btn-outline-secondary" @onclick="GoToPreviousPageAsync" disabled="@(!CanGoPreviousPage)">@L["Users.Pagination.Previous"]</button>
                            <span class="btn btn-outline-secondary disabled">@L["Users.Pagination.Page", _currentPage, TotalPages]</span>
                            <button type="button" class="btn btn-outline-secondary" @onclick="GoToNextPageAsync" disabled="@(!CanGoNextPage)">@L["Users.Pagination.Next"]</button>
                        </div>
                    </div>
                }
            </section>
        </div>

        @if (_panelMode != UserPanelMode.None)
        {
            <div class="users-dialog-backdrop" @onclick="ClosePanel">
                <aside class="users-surface users-surface--panel users-dialog" aria-live="polite" role="dialog" aria-modal="true" aria-labelledby="users-panel-title" @onclick:stopPropagation="true">
                    <div class="users-panel__header">
                        <div>
                            <p class="users-kicker mb-2">@L["Users.Panel.Kicker"]</p>
                            <h2 id="users-panel-title" class="h4 mb-1">@PanelTitle</h2>
                            <p class="text-secondary mb-0">@PanelDescription</p>
                        </div>
                        @if (_panelMode == UserPanelMode.Details && _selectedUser is not null && !_selectedUser.EmailConfirmed)
                        {
                            <AuthorizeView Roles="@AuthorizationPolicies.AdministratorRole">
                                <button
                                    type="button"
                                    class="btn btn-outline-success"
                                    @onclick="ConfirmSelectedUserAccountAsync"
                                    disabled="@_isSaving">
                                    @L["Users.Action.ConfirmAccount"]
                                </button>
                            </AuthorizeView>
                        }
                    </div>

                    @if (!string.IsNullOrWhiteSpace(_errorMessage))
                    {
                        <div class="alert alert-danger" role="alert">@_errorMessage</div>
                    }

                    @switch (_panelMode)
                    {
                        case UserPanelMode.Create:
                            <UserCreateForm IsSaving="_isSaving" OnSubmit="OnCreateUserSubmitted" OnCancel="ClosePanel" />
                            break;
                        case UserPanelMode.Details when _selectedUser is not null:
                            <UserDetailsView
                                User="_selectedUser"
                                IsSaving="_isSaving"
                                OnEdit="() => OpenEditPanelAsync(_selectedUser.Id)"
                                OnDelete="() => OpenDeletePanelAsync(_selectedUser.Id)"
                                OnCopyConfirmationLink="CopyConfirmationLinkAsync"
                                OnClose="ClosePanel" />
                            break;
                        case UserPanelMode.Edit when _selectedUser is not null:
                            <UserEditForm
                                User="_selectedUser"
                                IsSaving="_isSaving"
                                OnSubmit="OnUpdateUserSubmitted"
                                OnCancel="ClosePanel" />
                            break;
                        case UserPanelMode.Delete when _selectedUser is not null:
                            <UserDeleteConfirmation
                                User="_selectedUser"
                                IsSaving="_isSaving"
                                OnConfirm="DeleteUserAsync"
                                OnCancel="ClosePanel" />
                            break;
                    }
                </aside>
            </div>
        }
    </div>
</section>
