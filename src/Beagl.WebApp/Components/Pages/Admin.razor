@page "/admin"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@attribute [Authorize(Policy = AuthorizationPolicies.EmployeeAccess, Roles = AuthorizationPolicies.AdministratorRole)]

<PageTitle>@L["Admin.PageTitle"]</PageTitle>

<section class="admin-page-shell">
    <div class="crm-content">
        <div class="admin-hero mb-4 mb-lg-5">
            <div>
                <p class="admin-kicker mb-2">@L["Admin.Kicker"]</p>
                <h1 class="crm-page-title">@L["Admin.Title"]</h1>
                <p class="admin-hero__copy mb-0">@L["Admin.Copy"]</p>
            </div>
        </div>

        <div class="admin-tabs mb-3">
            <ul class="nav nav-tabs admin-tabs__nav" role="tablist">
                <li class="nav-item" role="presentation">
                    <button type="button"
                            class="nav-link @(_activeTab == _tabEmail ? "active" : string.Empty)"
                            id="tab-email"
                            role="tab"
                            aria-controls="tab-panel-email"
                            aria-selected="@(_activeTab == _tabEmail)"
                            @onclick='() => SetTab(_tabEmail)'>
                        @L["Admin.Tab.Email"]
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button type="button"
                            class="nav-link @(_activeTab == _tabBreeds ? "active" : string.Empty)"
                            id="tab-breeds"
                            role="tab"
                            aria-controls="tab-panel-breeds"
                            aria-selected="@(_activeTab == _tabBreeds)"
                            @onclick='() => SetTab(_tabBreeds)'>
                        @L["Admin.Tab.Breeds"]
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button type="button"
                            class="nav-link @(_activeTab == _tabColors ? "active" : string.Empty)"
                            id="tab-colors"
                            role="tab"
                            aria-controls="tab-panel-colors"
                            aria-selected="@(_activeTab == _tabColors)"
                            @onclick='() => SetTab(_tabColors)'>
                        @L["Admin.Tab.Colors"]
                    </button>
                </li>
            </ul>
        </div>

        <div class="tab-content">
            @if (_activeTab == _tabEmail)
            {
                <div id="tab-panel-email"
                     class="tab-pane show active"
                     role="tabpanel"
                     aria-labelledby="tab-email">
                    <EmailConfigTab />
                </div>
            }
            @if (_activeTab == _tabBreeds)
            {
                <div id="tab-panel-breeds"
                     class="tab-pane show active"
                     role="tabpanel"
                     aria-labelledby="tab-breeds">
                    <BreedsTab />
                </div>
            }
            @if (_activeTab == _tabColors)
            {
                <div id="tab-panel-colors"
                     class="tab-pane show active"
                     role="tabpanel"
                     aria-labelledby="tab-colors">
                    <ColorsTab />
                </div>
            }
        </div>
    </div>
</section>
