@page "/account/login"
@model Beagl.WebApp.Pages.Account.LoginModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<Beagl.WebApp.Resources.AuthResource> L
@{
    ViewData["Title"] = L["Auth.Login.PageTitle"];
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap-icons/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/app.css" />
    <link rel="stylesheet" href="~/Beagl.WebApp.styles.css" />
</head>
<body>
    <section class="auth-page-shell" aria-label="@L["Auth.Login.PageTitle"]">
        <article class="auth-card">
            <a class="app-shell__brand text-decoration-none mb-3" href="/">
                <span class="app-shell__brand-mark">
                    <img class="app-shell__brand-logo" src="~/images/beagl_logo.png" alt="@L["Auth.Login.Brand.Alt"]" />
                </span>
                <span>@L["Auth.Login.Brand.Name"]</span>
            </a>
            <p class="auth-kicker">@L["Auth.Login.Kicker"]</p>
            <h1 class="auth-heading">@L["Auth.Login.Title"]</h1>
            <p class="auth-copy">@L["Auth.Login.Description"]</p>

            <form method="post" class="auth-form" novalidate>
                @Html.AntiForgeryToken()
                <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger auth-error" role="alert" aria-live="assertive">
                        <div asp-validation-summary="ModelOnly"></div>
                    </div>
                }

                <div class="auth-field">
                    <label class="form-label" asp-for="Input.Identifier">@L["Auth.Login.Identifier.Label"]</label>
                    <input asp-for="Input.Identifier" class="form-control" placeholder="@L["Auth.Login.Identifier.Placeholder"]" autocomplete="username" />
                </div>

                <div class="auth-field">
                    <label class="form-label" asp-for="Input.Password">@L["Auth.Login.Password.Label"]</label>
                    <input asp-for="Input.Password" type="password" class="form-control" autocomplete="current-password" />
                </div>

                <div class="auth-actions">
                    <div class="form-check">
                        <input class="form-check-input" asp-for="Input.RememberMe" />
                        <label class="form-check-label" asp-for="Input.RememberMe">@L["Auth.Login.RememberMe"]</label>
                    </div>
                    <button type="submit" class="btn btn-primary px-4">@L["Auth.Login.Action.Submit"]</button>
                </div>

                <p class="auth-copy mt-2">
                    <a href="/account/forgot-password">@L["Auth.Login.Action.ForgotPassword"]</a>
                    &middot;
                    <a href="/account/recover">@L["Auth.Login.Action.RecoverAccount"]</a>
                </p>

                <p class="auth-copy mt-2">
                    @L["Auth.Login.NoAccount"]
                    <a href="/register">@L["Auth.Login.Action.Register"]</a>
                </p>
            </form>
        </article>
    </section>
</body>
</html>
