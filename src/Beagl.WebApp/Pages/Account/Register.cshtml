@page "/register"
@model Beagl.WebApp.Pages.Account.RegisterModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<Beagl.WebApp.Resources.AuthResource> L
@{
    ViewData["Title"] = L["Auth.Register.PageTitle"];
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap-icons/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/app.css" />
    <link rel="stylesheet" href="~/Beagl.WebApp.styles.css" />
</head>
<body>
    <section class="auth-page-shell" aria-label="@L["Auth.Register.PageTitle"]">
        <article class="auth-card">
            <a class="app-shell__brand text-decoration-none mb-3" href="/">
                <span class="app-shell__brand-mark">
                    <img class="app-shell__brand-logo" src="~/images/beagl_logo.png" alt="@L["Auth.Login.Brand.Alt"]" />
                </span>
                <span>@L["Auth.Login.Brand.Name"]</span>
            </a>
            <p class="auth-kicker">@L["Auth.Register.Kicker"]</p>
            <h1 class="auth-heading">@L["Auth.Register.Title"]</h1>
            <p class="auth-copy">@L["Auth.Register.Description"]</p>

            <form method="post" class="auth-form" novalidate>
                @Html.AntiForgeryToken()

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger auth-error" role="alert" aria-live="assertive">
                        <div asp-validation-summary="ModelOnly"></div>
                    </div>
                }

                <div class="auth-field">
                    <label class="form-label" asp-for="Input.FirstName">@L["Auth.Register.FirstName.Label"]</label>
                    <input asp-for="Input.FirstName" class="form-control" autocomplete="given-name" />
                    <span asp-validation-for="Input.FirstName" class="auth-field-error"></span>
                </div>

                <div class="auth-field">
                    <label class="form-label" asp-for="Input.LastName">@L["Auth.Register.LastName.Label"]</label>
                    <input asp-for="Input.LastName" class="form-control" autocomplete="family-name" />
                    <span asp-validation-for="Input.LastName" class="auth-field-error"></span>
                </div>

                <div class="auth-field">
                    <label class="form-label" asp-for="Input.UserName">@L["Auth.Register.UserName.Label"]</label>
                    <input asp-for="Input.UserName" class="form-control" autocomplete="username" />
                    <span asp-validation-for="Input.UserName" class="auth-field-error"></span>
                </div>

                <div class="auth-field">
                    <label class="form-label" asp-for="Input.PhoneNumber">@L["Auth.Register.PhoneNumber.Label"]</label>
                    <input asp-for="Input.PhoneNumber" type="tel" class="form-control" autocomplete="tel" />
                    <span asp-validation-for="Input.PhoneNumber" class="auth-field-error"></span>
                </div>

                <div class="auth-field">
                    <label class="form-label" asp-for="Input.Email">
                        @L["Auth.Register.Email.Label"]
                        <span class="auth-optional">@L["Auth.Register.Optional"]</span>
                    </label>
                    <input asp-for="Input.Email" type="email" class="form-control" autocomplete="email" />
                    <span asp-validation-for="Input.Email" class="auth-field-error"></span>
                </div>

                <div class="auth-field">
                    <label class="form-label" asp-for="Input.Password">@L["Auth.Register.Password.Label"]</label>
                    <input asp-for="Input.Password" type="password" class="form-control" autocomplete="new-password" />
                    <p class="auth-hint">@L["Auth.Register.Password.Hint"]</p>
                    <span asp-validation-for="Input.Password" class="auth-field-error"></span>
                </div>

                <div class="auth-actions">
                    <button type="submit" class="btn btn-primary px-4">@L["Auth.Register.Action.Submit"]</button>
                </div>

                <p class="auth-copy mt-2">
                    @L["Auth.Register.AlreadyHaveAccount"]
                    <a href="/account/login">@L["Auth.Register.Action.SignIn"]</a>
                </p>
            </form>
        </article>
    </section>
</body>
</html>
